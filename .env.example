# MAMMA path overrides. Copy to .env.local and uncomment lines to change defaults.
# Regenerate from registry: python -m inference dump-env-example -o .env.example
#
# MAMMA_YOLO_CHECKPOINT=data/weights/yolo/yolo12x.pt

# Used only when --sam_version sam2. Path to the SAM2 hiera-large
# checkpoint. Default points to the documented data/ layout.
# MAMMA_SAM2_CHECKPOINT=data/weights/sam2/sam2.1_hiera_large.pt
# MAMMA_SMPLX_LOCKHEAD_MODELS=data/body_models/smplx_locked_head
# MAMMA_DOWNSAMPLED_VERTS_PKL=data/body_models/downsampled_verts/verts_512.pkl
# MAMMA_MA2D_CHECKPOINT=data/weights/ma_2d/mamma_mask_full_cvpr.ckpt
# MAMMA_BUN_MODELS=
# MAMMA_PART_MESH_PATH=
