Bootstrap: docker
From: nvidia/cuda:12.6.2-cudnn-runtime-ubuntu22.04

%labels
    Description     "ma_masks: SAM2+SAM3 segmentation pipeline for MAMMA"

%environment
    export PYTHONUNBUFFERED=1
    export PIP_NO_CACHE_DIR=1
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

    export MAMBA_ROOT_PREFIX=/opt/micromamba
    export SAM_ENV_NAME=sam_env
    export PATH=/opt/micromamba/envs/${SAM_ENV_NAME}/bin:/opt/micromamba/bin:$PATH

    # HuggingFace token for SAM3 (set at runtime: --env HF_TOKEN=...)
    # export HF_TOKEN=<your_token>

%post
    set -eux

    # System deps
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        bash git curl wget ca-certificates \
        gcc g++ ninja-build \
        ffmpeg libgl1 libglib2.0-0 bzip2
    rm -rf /var/lib/apt/lists/*

    # 1. Install micromamba
    mkdir -p /opt/micromamba
    curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/latest \
        | tar -xvj -C /usr/local/bin/ --strip-components=1 bin/micromamba

    export MAMBA_ROOT_PREFIX=/opt/micromamba
    export SAM_ENV_NAME=sam_env

    # 2. Create Python 3.12 environment
    micromamba create -y -n "${SAM_ENV_NAME}" -c conda-forge python=3.12 pip
    micromamba run -n "${SAM_ENV_NAME}" \
        python -m pip install --upgrade pip "setuptools<81" wheel

    # 3. Install PyTorch (CUDA 12.6)
    micromamba run -n "${SAM_ENV_NAME}" \
        python -m pip install torch torchvision --index-url https://download.pytorch.org/whl/cu126

    # 4. Install project dependencies (SAM2, YOLO, CLIP, etc.)
    if [ -f /opt/masks/requirements.txt ]; then
        micromamba run -n "${SAM_ENV_NAME}" \
            python -m pip install -r /opt/masks/requirements.txt
    else
        echo "WARNING: /opt/masks/requirements.txt not found."
    fi

    # 5. Install SAM3 and its dependencies (optional — comment out if not needed)
    micromamba run -n "${SAM_ENV_NAME}" \
        python -m pip install decord
    micromamba run -n "${SAM_ENV_NAME}" \
        python -m pip install git+https://github.com/facebookresearch/sam3.git || \
        echo "WARNING: SAM3 installation failed (may need HF_TOKEN at runtime)"

    # 6. Download SAM2 weights
    mkdir -p /opt/masks/weights
    wget -q -O /opt/masks/weights/sam2.1_hiera_large.pt \
        https://dl.fbaipublicfiles.com/segment_anything_2/092824/sam2.1_hiera_large.pt || \
        echo "WARNING: SAM2 weights download failed. Bind-mount or set SAM2_CHECKPOINT."

    # Clean caches
    micromamba clean --all -y || true

%files
    requirements.txt /opt/masks/requirements.txt
    run_ma_masks.py /opt/masks/run_ma_masks.py
    process_sequence.py /opt/masks/process_sequence.py
    configs /opt/masks/configs
    core /opt/masks/core
    utils /opt/masks/utils
    scripts /opt/masks/scripts

%runscript
    cd /opt/masks
    exec python "$@"

%help
    ma_masks: Multi-camera segmentation mask export for the MAMMA pipeline.

    Usage:
      # SAM2 (default)
      apptainer run --nv container.sif run_ma_masks.py \
        --ma_cap_dir /path/to/data --seq_name my_seq --out output/

      # SAM3 prompt mode (requires HF_TOKEN for first run)
      apptainer run --nv --env HF_TOKEN=$HF_TOKEN container.sif run_ma_masks.py \
        --ma_cap_dir /path/to/data --seq_name my_seq --out output/ \
        --sam_version sam3_prompt
